<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Khajuraho Riksas</title>

<style>
body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#f4f4f4;
}

header{
    background:#0a7a4b;
    color:white;
    text-align:center;
    padding:20px;
}

.hero{
    text-align:center;
    padding:40px 20px;
    background:white;
}

.hero h1{
    color:#0a7a4b;
}

.booking-form{
    max-width:600px;
    margin:20px auto;
    background:white;
    padding:20px;
    border-radius:10px;
}

.booking-form input,
.booking-form select{
    width:100%;
    padding:12px;
    margin:10px 0;
}

button{
    width:100%;
    padding:14px;
    background:#0a7a4b;
    color:white;
    border:none;
    cursor:pointer;
}

.services{
    max-width:900px;
    margin:20px auto;
    background:white;
    padding:20px;
    border-radius:10px;
}

.services ul{
    line-height:2;
}
</style>
</head>

<body>

<header>
    <h1>Khajuraho Riksas</h1>
    <p>E-Rickshaw Booking & Tourist Tours</p>
</header>

<section class="hero">
    <h1>Book Your Ride in Khajuraho</h1>
    <p>Temple Tours, Airport Pickup, Railway Station, Raneh Falls & More</p>
</section>

<div class="booking-form">
    <h2>Book Now</h2>

    <input type="text" placeholder="Your Name">

    <input type="tel" placeholder="Mobile Number">

    <input type="text" placeholder="Pickup Location">

    <select>
        <option>Select Destination</option>
        <option>Western Temples</option>
        <option>Eastern Temples</option>
        <option>Airport</option>
        <option>Railway Station</option>
        <option>Panna Tiger Reserve</option>
        <option>Pandav Falls</option>
        <option>Raneh Falls</option>
        <option>Bateshwar Dham</option>
        <option>Archaeological Museum</option>
        <option>Light & Sound Show</option>
    </select>

    <input type="datetime-local">

    <button>Book Ride</button>
</div>

<div class="services">
    <h2>Our Services</h2>

    <ul>
        <li>Khajuraho Temple Tour</li>
        <li>Airport Pickup & Drop</li>
        <li>Railway Station Pickup & Drop</li>
        <li>Panna Tiger Reserve Tour</li>
        <li>Pandav Falls Visit</li>
        <li>Raneh Falls Visit</li>
        <li>Bateshwar Dham Visit</li>
        <li>Archaeological Museum Visit</li>
        <li>Light & Sound Show Transport</li>
        <li>Hotel Pickup & Drop</li>
        <li>Full-Day Sightseeing Package</li>
    </ul>
</div>

</body>
</html>